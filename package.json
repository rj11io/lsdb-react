{
  "name": "@rj11io/lsdb-react",
  "version": "1.0.0",
  "description": "LSDB React bindings",
  "homepage": "https://github.com/rj11io/lsdb-react#readme",
  "bugs": {
    "url": "https://github.com/rj11io/lsdb-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rj11io/lsdb-react.git"
  },
  "license": "Apache-2.0",
  "author": "rj11io",
  "private": false,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "npm run build && node -e \"require('./dist/index.js')\"",
    "test": "npm run lint && playwright test",
    "prepack": "npm run build",
    "semantic-release": "semantic-release"
  },
  "overrides": {
    "lodash-es": "4.17.21"
  },
  "peerDependencies": {
    "@rj11io/lsdb": "^1.0.1",
    "react": ">=18"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/npm": "12.0.2",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@playwright/test": "1.53.2",
    "@rj11io/lsdb": "file:../lsdb",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@vitejs/plugin-react": "4.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "semantic-release": "24.2.7",
    "typescript": "5.8.3",
    "vite": "7.1.12"
  }
}
